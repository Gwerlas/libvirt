{# https://libvirt.org/formatnetwork.html #}
<network>
  <name>{{ network.name }}</name>
{% if 'forward' in network %}
  <forward mode='{{ network.forward.mode | default('nat') }}'/>
{% endif %}
{% if 'bridge' in network %}
  <bridge name='{{ network.bridge.name }}'/>
{% endif %}
{% for ip in network.ips | default([]) %}
  <ip address='{{ ip.address }}' netmask='{{ ip.netmask }}'>
{% if 'dhcp' in ip %}
    <dhcp>
{% for range in ip.dhcp.ranges %}
      <range start='{{ range.start }}' end='{{ range.end }}'/>
{% endfor %}
    </dhcp>
{% endif %}
  </ip>
{% endfor %}
</network>
